# Copy this file to .env and fill in your own values. Never commit .env.

# --- AWS ---
# Leave the key/secret pair blank to fall back to ~/.aws/credentials or an
# instance/role profile instead. AWS_PROFILE takes precedence if set.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_PROFILE=
AWS_REGION=us-east-1

# Which regions to scan for REGIONAL resources (security groups, EBS, RDS).
#   blank  -> only AWS_REGION (fastest; the default)
#   all    -> every region enabled on the account (slower, needs ec2:DescribeRegions)
#   a,b,c  -> exactly these regions
# S3, IAM and CloudTrail are global and are always scanned once regardless.
AWS_REGIONS=

# --- Groq (AI explanations) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Web app auth ---
# Signs the session cookie. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# If left blank a random one is used, which logs everyone out on each restart.
SESSION_SECRET=
# Set to true ONLY when serving over HTTPS. On plain-HTTP localhost this must stay
# false, or the browser silently drops the cookie and login appears to do nothing.
SESSION_HTTPS_ONLY=false

# --- IAM detector ---
# Access keys unused for this many days are flagged. Set to 0 to test the check
# against a freshly created key.
IAM_UNUSED_KEY_DAYS=90

# --- Scheduled scans ---
SCAN_SCHEDULE_ENABLED=false
# Standard 5-field cron: minute hour day month weekday. Default = 02:00 daily.
SCAN_SCHEDULE_CRON=0 2 * * *

# --- Email alerts (sent when a scheduled scan finds a NEW issue) ---
# Unchanged findings are never re-sent, so a nightly scan won't spam you.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=
# Comma-separated recipients.
ALERT_TO=

# --- Remediation (WRITE access to your AWS account) ---
# Off by default: CloudSentinel is read-only unless you opt in. Enabling this
# also requires granting the write permissions listed in the README.
REMEDIATION_ENABLED=false
